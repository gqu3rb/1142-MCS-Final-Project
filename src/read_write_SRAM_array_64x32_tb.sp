.title Read Write 64x32 SRAM Array Simulation
*****************************
**     Library setting     **
*****************************
.protect
.include '7nm_TT.pm'
.unprotect
.include '6to64_row_decoder.sp'
.include 'SRAM_array_64x32.sp'
.include 'column_based_circuit.sp'
.include 'DFF.sp'

